{
  "name": "slack-api-cli",
  "version": "0.1.1",
  "description": "A local Slack CLI that reuses a signed-in browser session for search, read, and dry-run-safe message workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronnie3786/slack-api-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ronnie3786/slack-api-cli/issues"
  },
  "homepage": "https://github.com/ronnie3786/slack-api-cli#readme",
  "type": "commonjs",
  "bin": {
    "slack-api": "slack-api.cjs"
  },
  "scripts": {
    "api": "node slack-api.cjs",
    "api:help": "node slack-api.cjs --help",
    "api:setup": "node slack-api-setup.cjs",
    "api:auth": "node slack-api-auth.cjs",
    "api:me": "node slack-api-me.cjs",
    "api:search": "node slack-api-search.cjs",
    "api:read": "node slack-api-read.cjs",
    "api:channel": "node slack-api-channel.cjs",
    "api:dm": "node slack-api-dm.cjs",
    "api:user": "node slack-api-user.cjs",
    "api:file": "node slack-api-file.cjs",
    "api:send": "node slack-api-send.cjs",
    "api:draft": "node slack-api-draft.cjs",
    "api:emoji": "node slack-api-emoji.cjs",
    "api:reply": "node slack-api-reply.cjs",
    "api:react": "node slack-api-react.cjs"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "files": [
    "slack-api*.cjs",
    "LICENSE",
    "README.md",
    "docs/**/*.md"
  ],
  "engines": {
    "node": ">=20"
  }
}
